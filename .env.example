# =============================================================================
# Variables de entorno para Scrapers
# =============================================================================
# Copiar este archivo a .env y completar con valores reales

# ===== CREDENCIALES ODOO =====
# IMPORTANTE: Todos los scrapers usan estas variables
ODOO_URL=https://pldistribucion.adhoc.ar
ODOO_DB=odoo
ODOO_USER=usuario@ejemplo.com
ODOO_PASSWORD=tu_password_odoo

# ===== CREDENCIALES PR AUTOPARTES =====
PRAUTO_USERNAME=tu_usuario_prauto
PRAUTO_PASSWORD=tu_password_prauto

# ===== CREDENCIALES PORTAL SV (Servicios Viales) =====
SV_USERNAME=tu_email@ejemplo.com
SV_PASSWORD=tu_password_sv

# ===== CREDENCIALES BLUECAR (opcional, no implementado aún) =====
# BLUECAR_EMAIL=tu_email@ejemplo.com
# BLUECAR_PASSWORD=tu_password_bluecar

# ===== CONFIGURACION GENERAL =====
HEADLESS=true
OUTPUT_DIR=./output
PM2_LOG_DIR=./logs

# ===== DOCKER - SCHEDULES (cron format) =====
# Todos los scrapers juntos (RECOMENDADO)
SCRAPERS_SCHEDULE=0 */4 * * *

# Scrapers individuales (NO recomendado)
# PR_SCHEDULE=0 */2 * * *
# SV_SCHEDULE=0 */4 * * *
